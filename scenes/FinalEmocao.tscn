[node name="FinalEmocao" instance=ExtResource("1_base")]
mostrar_monitor = false
escala_conteudo = 1.5
texto = "E no fim, o melhor jeito de resolver o bug foi deletando a startup da própria vida: João mandou o chefe e os prazos pro espaço, trocou as olheiras por um bronzeado e uma barba rala e foi ser feliz vendedora de arte física na praia. Agora, de bermuda florida em sua barraquinha sob o sol com o aviso \"I DON'T CODE ANYMORE\", ele sorri limpando a mente enquanto um teclado velho é levado pela maré da liberdade."
